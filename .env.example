APP_NAME=Zap Automation API
APP_ENV=development
API_PREFIX=/api/v1
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ISSUER=zap-automation
JWT_AUDIENCE=zap-automation-app
JWT_CLOCK_SKEW_SECONDS=30
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=zap_automation
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
# Local example:
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1
# Production example:
# FRONTEND_ORIGINS=https://app.seudominio.com
# TRUSTED_HOSTS=api.seudominio.com,zap-automation.onrender.com
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_ENABLED=false
REDIS_STREAM_CONSUMER_ENABLED=true
REDIS_STREAM_KEY=zap_automation:whatsapp_events
REDIS_STREAM_GROUP=whatsapp_automation_workers
REDIS_STREAM_CONSUMER_NAME=api-worker
REDIS_STREAM_BLOCK_MS=5000
REDIS_STREAM_BATCH_SIZE=20
REDIS_STREAM_MAXLEN=10000
REDIS_STREAM_MAX_ATTEMPTS=3
REDIS_DEAD_LETTER_KEY=zap_automation:whatsapp_events:dlq
PROVIDER_SEND_RETRIES=3
PROVIDER_RETRY_BACKOFF_MS=700
WHATSAPP_VERIFY_TOKEN=meta-verify-token
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_GRAPH_URL=https://graph.facebook.com
WHATSAPP_REQUEST_TIMEOUT_SECONDS=20
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# For production, prefer your own WhatsApp sender instead of the Twilio Sandbox number (+14155238886).
TWILIO_WHATSAPP_NUMBER=
OPENAI_API_KEY=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENABLE_LOGS=true
PUBLIC_CHECKOUT_STARTER_URL=
PUBLIC_CHECKOUT_SMARTER_URL=
PUBLIC_CONTACT_WHATSAPP=
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT_REQUESTS=240
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
MAX_REQUEST_BODY_BYTES=1048576
WEBHOOK_MAX_BODY_BYTES=262144
DEFAULT_ADMIN_EMAIL=admin@zapautomation.local
DEFAULT_ADMIN_PASSWORD=admin123
